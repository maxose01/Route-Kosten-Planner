{
  "name": "route-cost-app",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n API,WEB -c blue,green \"npm run dev -w @route-cost/api\" \"npm run dev -w @route-cost/web\"",
    "dev:api": "npm run dev -w @route-cost/api",
    "dev:api:plain": "npm run dev:plain -w @route-cost/api",
    "dev:web": "npm run dev -w @route-cost/web",
    "build": "npm run build --workspaces",
    "test": "npm run test -w @route-cost/api"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.8.3"
  },
  "optionalDependencies": {
    "@esbuild/darwin-arm64": "^0.27.7"
  }
}
